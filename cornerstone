<script>
let savedCount = 0;

function showScreen(name) {
  document.getElementById('screen-landing').style.display = 'none';
  document.getElementById('onboarding').classList.add('hidden');
  document.getElementById('screen-feed').style.display = 'none';
  document.getElementById('screen-feed').classList.add('hidden');

  const intakeIds = ['screen-trust','screen-intake1','screen-intake2','screen-intake3','screen-legacy'];

  if (name === 'trust') {
    document.getElementById('onboarding').classList.remove('hidden');
    intakeIds.forEach(id => { const el = document.getElementById(id); el.classList.add('hidden'); el.style.display='none'; });
    const t = document.getElementById('screen-trust');
    t.classList.remove('hidden'); t.style.display='flex';
  } else if (['intake1','intake2','intake3'].includes(name)) {
    document.getElementById('onboarding').classList.remove('hidden');
    intakeIds.forEach(id => { const el = document.getElementById(id); el.classList.add('hidden'); el.style.display='none'; });
    const el = document.getElementById('screen-' + name);
    el.classList.remove('hidden'); el.style.display='flex';
  } else if (name === 'legacy') {
    document.getElementById('onboarding').classList.remove('hidden');
    intakeIds.forEach(id => { const el = document.getElementById(id); el.classList.add('hidden'); el.style.display='none'; });
    const fn = document.getElementById('farm-name');
    if (fn && fn.value) { const ln = document.getElementById('leg-name'); if(ln) ln.value = fn.value; }
    const leg = document.getElementById('screen-legacy');
    leg.classList.remove('hidden'); leg.style.display='grid';
  } else if (name === 'feed') {
    const fn = document.getElementById('farm-name');
    if (fn && fn.value) {
      const wn = document.getElementById('welcome-name');
      const sfn = document.getElementById('sidebar-farm-name');
      if (wn) wn.textContent = fn.value;
      if (sfn) sfn.textContent = fn.value;
    }
    const feed = document.getElementById('screen-feed');
    feed.classList.remove('hidden'); feed.style.display='flex';
  }
}

function selectPath(el) {
  document.querySelectorAll('.path-opt').forEach(o => o.classList.remove('sel'));
  el.classList.add('sel');
  const btn = document.getElementById('path-btn');
  btn.style.opacity = '1'; btn.style.pointerEvents = 'auto';
}

function setTab(el) {
  document.querySelectorAll('.feed-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
}

function savePost(btn, farmName, title) {
  if (btn.classList.contains('saved')) return;
  btn.classList.add('saved');
  btn.innerHTML = '<svg viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" style="width:13px;height:13px"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg> Saved';
  savedCount++;
  document.getElementById('wisdom-count').textContent = savedCount;
  const wl = document.getElementById('wisdom-list');
  if (savedCount === 1) wl.innerHTML = '';
  const item = document.createElement('div');
  item.className = 'wisdom-item';
  item.innerHTML = '<div class="wisdom-ico">📌</div><div><div class="wisdom-text">' + title.slice(0,52) + '...</div><div class="wisdom-farm">' + farmName + '</div></div>';
  wl.appendChild(item);
  const toast = document.getElementById('toast');
  toast.classList.add('show');
  setTimeout(() => toast.classList.remove('show'), 2800);
}

document.getElementById('screen-landing').style.display = 'flex';
</script>

